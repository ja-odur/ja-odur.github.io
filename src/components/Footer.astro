---
import { profile } from '~/data/profile';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container--wide footer-inner">
    <div class="footer-left mono">
      <span>© {year} Joseph Odur</span>
      <button
        type="button"
        class="joke-trigger"
        id="joke-trigger"
        aria-label="A small joke about hard problems"
        title="There are only two hard things…"
      >
        {'{;}'}
      </button>
    </div>

    <ul class="footer-links mono">
      <li><a href={`mailto:${profile.email}`}>email</a></li>
      <li><a href={profile.github} target="_blank" rel="noreferrer">github</a></li>
      <li><a href={profile.repo} target="_blank" rel="noreferrer">source</a></li>
      <li><a href="/llms.txt">llms.txt</a></li>
    </ul>

    <button type="button" class="terminal-hint mono" id="terminal-open">
      <span aria-hidden="true">❯</span> terminal
      <span class="cursor" aria-hidden="true">_</span>
    </button>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(4rem, 10vh, 7rem);
    border-top: 1px solid var(--border);
    padding-block: 1.5rem;
    font-size: 0.8125rem;
    color: var(--text-faint);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .joke-trigger {
    color: var(--text-faint);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    padding: 0.1rem 0.3rem;
    border-radius: var(--radius-sm);
    transition: color var(--speed) var(--ease);
  }

  .joke-trigger:hover {
    color: var(--accent);
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-links a {
    color: var(--text-faint);
    text-decoration: none;
  }

  .footer-links a:hover {
    color: var(--accent);
  }

  .terminal-hint {
    color: var(--text-faint);
    font-size: 0.8125rem;
    padding: 0.25rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--speed) var(--ease),
      border-color var(--speed) var(--ease);
  }

  .terminal-hint:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .terminal-hint span:first-child {
    color: var(--accent);
  }

  @media (prefers-reduced-motion: no-preference) {
    .cursor {
      animation: blink 1.2s steps(1) infinite;
    }

    @keyframes blink {
      50% {
        opacity: 0;
      }
    }
  }
</style>
